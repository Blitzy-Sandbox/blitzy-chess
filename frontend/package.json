{
  "name": "chess-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chess.js": "^1.0.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "10.5.0",
    "eslint": "^9.39.4",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0",
    "typescript-eslint": "8.60.1",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
